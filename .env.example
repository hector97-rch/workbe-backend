PORT=3000

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=mydb

# Docker: host is the compose service name `mongodb`
MONGO_URI=mongodb://admin:changeme@mongodb:27017/mydb?authSource=admin

# Local Nest (no Docker): use localhost and match your Mongo auth
# MONGO_URI=mongodb://127.0.0.1:27017/mydb?authSource=admin
