PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workbe
POSTGRES_PORT=5432

# Docker: host is the compose service name `postgres`
DATABASE_URL=postgres://postgres:postgres@postgres:5432/workbe

# Local Nest (no Docker): use localhost
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/workbe
